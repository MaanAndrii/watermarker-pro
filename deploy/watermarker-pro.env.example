# Copy to /etc/watermarker-pro.env and adjust values.

# Where temporary sessions/uploads are stored
WM_WORK_DIR=/var/lib/watermarker/tmp

# Optional runtime limits for Raspberry Pi
WM_MAX_FILE_SIZE_MB=50
WM_MAX_IMAGE_DIMENSION=8000
WM_MAX_THREADS=4
WM_DEFAULT_THREADS=2

# Streamlit transport limits (cannot be truly unlimited, but can be raised)
WM_STREAMLIT_MAX_UPLOAD_MB=1024
WM_STREAMLIT_MAX_MESSAGE_MB=1024
WM_STREAMLIT_PORT=8501
WM_STREAMLIT_ADDRESS=0.0.0.0
